{
  "name": "jiansheng-workspace",
  "type": "module",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run dev:web",
    "dev:web": "bun run --filter '@jiansheng/web' dev",
    "dev:admin": "bun run --filter '@jiansheng/admin' dev",
    "build": "bun run --filter '@jiansheng/web' build && bun run --filter '@jiansheng/admin' build",
    "typecheck": "bun run --filter '*' typecheck",
    "lint": "bun run --filter '*' lint",
    "lint:fix": "bun run --filter '*' lint --fix",
    "db:push": "bun run --filter '@jiansheng/admin' db:push",
    "db:studio": "bun run --filter '@jiansheng/admin' db:studio",
    "auth:createAdmin": "bun run --filter '@jiansheng/admin' auth:createAdmin"
  },
  "dependencies": {
    "taze": "^19.11.0"
  }
}
